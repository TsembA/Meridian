# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
dist/
build/
.eggs/
pip-log.txt
pip-delete-this-directory.txt

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
# Bandit/Trivy SARIF output — generated artifacts, not source
*.sarif
coverage.xml
.tox/

# ── Terraform ─────────────────────────────────────────────────────────────────
# Provider binaries — large, downloaded by terraform init; never commit
.terraform/
# Lock file should be committed for reproducible provider versions
!.terraform.lock.hcl
# Remote state is in S3 — never commit local state
*.tfstate
*.tfstate.backup
# Plan files may contain secrets
*.tfplan
# Local variable overrides — may contain secrets
terraform.tfvars
terraform.tfvars.json
*.auto.tfvars
*.auto.tfvars.json
crash.log
# Local provider overrides — not portable
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ── Helm ──────────────────────────────────────────────────────────────────────
# Do NOT ignore Chart.lock — commit it for reproducible deploys
# Do NOT ignore charts/ — subchart tarballs may be needed

# ── Secrets & credentials ─────────────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519
.env
.env.*
# Template files are fine to commit
!.env.example
secrets.yaml
secrets.yml

# ── Docker ────────────────────────────────────────────────────────────────────
.dockerignore.local
# Local overrides (custom ports, mounts) — not committed
docker-compose.override.yml

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
.project
.settings/
*.sublime-project
*.sublime-workspace

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── OS ────────────────────────────────────────────────────────────────────────
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
audit.jsonl
